<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Bucket.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Bucket Settings"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <!-- Settings-card look without an extra package dependency. -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
                <Setter Property="Padding" Value="16,12" />
            </Style>
        </Grid.Resources>

        <ScrollViewer Padding="24">
            <StackPanel Spacing="8" MaxWidth="640">
                <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8" />

                <!-- Keep running in tray -->
                <Border Style="{StaticResource Card}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Keep running in the system tray" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Closing the last bucket hides it to the tray instead of quitting."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="TrayToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="TrayToggle_Toggled" />
                    </Grid>
                </Border>

                <!-- Restore on launch -->
                <Border Style="{StaticResource Card}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Restore buckets on next launch" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Re-open buckets that still had items when the app last closed. References only — files are never moved."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="RestoreToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="RestoreToggle_Toggled" />
                    </Grid>
                </Border>

                <!-- Edge catcher -->
                <Border Style="{StaticResource Card}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Screen-edge catcher" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="A small tab on the right edge — drag files onto it to drop them straight into a bucket."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="EdgeToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="EdgeToggle_Toggled" />
                    </Grid>
                </Border>

                <!-- Shake to summon -->
                <Border Style="{StaticResource Card}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Shake to summon a bucket" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Shake the mouse to jump a bucket under the cursor — handy while dragging files."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="ShakeToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="ShakeToggle_Toggled" />
                    </Grid>
                </Border>

                <!-- Transparency -->
                <Border Style="{StaticResource Card}">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Window transparency" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="See-through level for bucket windows."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <TextBlock x:Name="OpacityValue" Grid.Column="1" VerticalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </Grid>
                        <Slider x:Name="OpacitySlider" Minimum="40" Maximum="100" StepFrequency="1"
                                TickFrequency="10" TickPlacement="Outside"
                                ValueChanged="OpacitySlider_ValueChanged" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
